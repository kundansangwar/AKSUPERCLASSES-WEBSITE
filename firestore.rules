rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the current user an admin?
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Students: a student can read/write their own profile.
    // Admins can read/write any student profile (for the admin dashboard).
    match /students/{studentId} {
      allow read, write: if request.auth != null
                         && (request.auth.uid == studentId || isAdmin());
    }

    // Admins collection:
    //   - Any signed-in user can read their own admin doc (to detect their
    //     admin status). Existing admins can read any admin doc (to list them).
    //   - Only existing admins can create, update, or delete admin docs. This
    //     means the FIRST admin must still be bootstrapped via the Firebase
    //     Console; after that, admins can manage each other from the website.
    match /admins/{adminId} {
      allow read: if request.auth != null
                  && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
